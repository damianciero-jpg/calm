# Firebase client config required by the app and by authenticated E2E tests.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Playwright test credentials for authenticated E2E tests.
# Use an account with at least one teen child profile so Daily Check-In can run.
# The seeded parent account documented in README is a good local default:
# PLAYWRIGHT_TEST_EMAIL=parent@test.calmpath
# PLAYWRIGHT_TEST_PASSWORD=CalmPath123!
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=

# Optional override if tests should target a server you start yourself.
PLAYWRIGHT_BASE_URL=
